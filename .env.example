# EcoTrace Environment Variables
# Copy this file to .env.local and adjust as needed

# Application
NEXT_PUBLIC_APP_URL=https://ecotrace.vercel.app
NEXT_PUBLIC_APP_VERSION=2.0.0

# Database (optional - falls back to in-memory)
# DATABASE_URL=postgresql://user:password@localhost:5432/ecotrace

# Features
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_CHAT=true
